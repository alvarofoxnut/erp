NODE_ENV=development
PORT=5000
# Production: use Neon pooled URL with ?sslmode=require
DATABASE_URL=postgresql://postgres@localhost:5433/makhana_erp?schema=public
# Same as DATABASE_URL for local Postgres; use Neon direct (non-pooler) URL in production
DIRECT_DATABASE_URL=postgresql://postgres@localhost:5433/makhana_erp?schema=public
# Production: use cryptographically random strings, minimum 32 characters each
JWT_ACCESS_SECRET=your_access_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_ACCESS_EXPIRES=15m
# Production: must not exceed 15m (enforced by validateEnv at startup)
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=http://localhost:5173
# Render + Vercel: set COOKIE_CROSS_ORIGIN=true on Render only
# COOKIE_CROSS_ORIGIN=true
# ALLOW_VERCEL_PREVIEWS=true
# Optional: override default seed admin password in development (default: admin123)
# Production seeding requires SEED_ADMIN_PASSWORD (min 12 chars, not admin123):
#   NODE_ENV=production SEED_ADMIN_PASSWORD=... node src/scripts/seed.js
# SEED_ADMIN_PASSWORD=your_secure_password
LOG_LEVEL=info
