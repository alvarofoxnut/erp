{
  "name": "makhana-erp-backend",
  "version": "1.0.0",
  "description": "Makhana Manufacturing & Trading ERP Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "build:deploy": "prisma generate && prisma migrate deploy",
    "predev": "npm run db:dev:start",
    "dev": "nodemon src/server.js",
    "seed": "node src/scripts/seed.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:backfill-fg-batches": "node src/scripts/backfill-fg-batches.js",
    "db:dev:init": "powershell -ExecutionPolicy Bypass -File scripts/dev-postgres.ps1 -Action init",
    "db:dev:start": "powershell -ExecutionPolicy Bypass -File scripts/dev-postgres.ps1 -Action start",
    "db:dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/dev-postgres.ps1 -Action stop",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^6.5.0"
  }
}
