# Docker Compose — copy to .env in project root before `docker-compose up`
# Required: cryptographically random strings, minimum 32 characters each
POSTGRES_PASSWORD=postgres
JWT_ACCESS_SECRET=replace_with_32_plus_char_random_access_secret
JWT_REFRESH_SECRET=replace_with_32_plus_char_random_refresh_secret
# Run seed once manually after first deploy: docker compose exec backend node src/scripts/seed.js
# SEED_ADMIN_PASSWORD=your_strong_admin_password_min_12_chars
